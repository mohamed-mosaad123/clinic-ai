API_URL=http://localhost:5000
DATABASE_URL=sqlite:///db.sqlite3
SECRET_KEY=change_me
AI_SERVICE_URL=http://localhost:8000
AWS_S3_BUCKET=
GOOGLE_MAPS_API_KEY=

# Add other keys used by your app here, for example:
# - EMAIL_HOST
# - PAYMENT_GATEWAY_KEY
# - THIRD_PARTY_API_KEY
# ─────────────────────────────────────────────
# ClinicAI FastAPI service – environment config
# Copy to .env and adjust values
# ─────────────────────────────────────────────

# Debug mode
DEBUG=false

# Path to the folder containing diabetes_model.pkl, heart_model.pkl, kidney_model.pkl
# Relative to ClinicAI/ directory
MODELS_DIR=../models

# CORS (restrict to .NET backend URL in production)
ALLOWED_ORIGINS=["*"]

# .NET backend base URL
BACKEND_URL=http://localhost:5001
